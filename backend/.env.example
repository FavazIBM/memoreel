# Server Configuration
SERVER_PORT=8080
SERVER_ADDRESS=0.0.0.0

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/memoreel
DATABASE_USERNAME=memoreel_user
DATABASE_PASSWORD=memoreel_password
DATABASE_DRIVER=org.postgresql.Driver

# JPA/Hibernate Configuration
JPA_SHOW_SQL=true
JPA_HIBERNATE_DDL_AUTO=validate
JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production-min-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=memoreel-media
AWS_S3_BUCKET_URL=https://memoreel-media.s3.amazonaws.com

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/oauth2/callback/google

# FFmpeg Configuration
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe

# Video Processing Configuration
VIDEO_MAX_DURATION=300
VIDEO_DEFAULT_RESOLUTION=1920x1080
VIDEO_DEFAULT_FPS=30
VIDEO_DEFAULT_BITRATE=5000k

# File Upload Configuration
FILE_UPLOAD_MAX_SIZE=104857600
FILE_UPLOAD_MAX_REQUEST_SIZE=524288000
FILE_UPLOAD_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/jpg
FILE_UPLOAD_ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo

# Batch Processing Configuration
BATCH_CHUNK_SIZE=10
BATCH_THREAD_POOL_SIZE=5

# Application Configuration
APP_NAME=Memoreel
APP_VERSION=1.0.0
APP_FRONTEND_URL=http://localhost:5173
APP_BACKEND_URL=http://localhost:8080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_ALLOW_CREDENTIALS=true

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_MEMOREEL=DEBUG
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK=INFO
LOGGING_LEVEL_ORG_HIBERNATE=INFO

# Actuator Configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# Session Configuration
SESSION_TIMEOUT=1800

# QR Code Configuration
QR_CODE_SIZE=300
QR_CODE_ERROR_CORRECTION=H
QR_CODE_MARGIN=1

# Email Configuration (Optional - for future use)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# Environment
SPRING_PROFILES_ACTIVE=dev