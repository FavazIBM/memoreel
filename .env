# Memoreel Environment Configuration

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=jdbc:postgresql://localhost:5433/memoreel
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=password
DATABASE_DRIVER=org.postgresql.Driver

# ============================================
# REDIS CONFIGURATION
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# ============================================
# AWS S3 CONFIGURATION
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=memoreel-media
AWS_S3_BUCKET_URL=https://memoreel-media.s3.amazonaws.com

# ============================================
# JWT CONFIGURATION
# ============================================
JWT_SECRET=my_super_secret_jwt_key_change_this
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ============================================
# GOOGLE OAUTH CONFIGURATION
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback

# ============================================
# FFMPEG CONFIGURATION
# ============================================
FFMPEG_PATH=C:/Users/ReethuJoseph/Downloads/ffmpeg-8.1.1/bin/ffmpeg.exe
FFPROBE_PATH=C:/Users/ReethuJoseph/Downloads/ffmpeg-8.1.1/bin/ffprobe.exe

# ============================================
# APPLICATION CONFIGURATION
# ============================================
APP_NAME=Memoreel
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080/api/v1

# Backend Server Configuration
SERVER_PORT=8080
SERVER_HOST=localhost

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:8080/api/v1
VITE_APP_NAME=Memoreel
VITE_GOOGLE_CLIENT_ID=

# ============================================
# FILE UPLOAD LIMITS
# ============================================
MAX_IMAGE_SIZE=5242880
MAX_VIDEO_SIZE=52428800
MAX_PROJECT_MEDIA_SIZE=524288000
MAX_MEDIA_PER_PROJECT=50

# ============================================
# VIDEO PROCESSING CONFIGURATION
# ============================================
VIDEO_PROCESSING_TIMEOUT=300000
VIDEO_OUTPUT_RESOLUTION=1080p
VIDEO_OUTPUT_FORMAT=mp4
MAX_CONCURRENT_JOBS=5

# ============================================
# QR CODE CONFIGURATION
# ============================================
QR_CODE_SIZE=512
QR_CODE_FORMAT=PNG
QR_CODE_ERROR_CORRECTION=H

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60000

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/memoreel.log

# ============================================
# CORS CONFIGURATION
# ============================================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*

# ============================================
# SESSION CONFIGURATION
# ============================================
SESSION_TIMEOUT=3600000
SESSION_COOKIE_NAME=MEMOREEL_SESSION

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@memoreel.app

# ============================================
# MONITORING & ANALYTICS (Optional)
# ============================================
SENTRY_DSN=
GOOGLE_ANALYTICS_ID=

# ============================================
# ENVIRONMENT
# ============================================
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev